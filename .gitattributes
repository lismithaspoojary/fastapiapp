# Normalize text files and enforce LF line endings in the repository.
* text=auto
*.css text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.svg text eol=lf
*.xml text eol=lf
*.txt text eol=lf
*.sh text eol=lf

# Binary files should not be normalized.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.pdf binary
*.zip binary
*.exe binary
*.dll binary
